{
	"name": "n8n-hooks-marketplace",
	"version": "1.0.0",
	"description": "Decentralized Workflow Marketplace for N8N Self Hosted Instances over MQTT",
	"type": "module",
	"scripts": {
		"build": "npm run build:shared && npm run build:backend && npm run build:bridge && npm run build:app",
		"build:shared": "tsup src/shared/index.ts --format esm,cjs --dts --out-dir dist/shared",
		"build:backend": "tsup --config tsup.backend.config.ts",
		"build:bridge": "tsup --config tsup.bridge.config.ts",
		"build:app": "vite build",
		"dev:app": "vite",
		"dev:n8n": "node --import tsx scripts/dev-n8n.ts",
		"dev": "npm run build && tsx scripts/dev.ts",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "vitest run",
		"test:e2e:cleanup": "tsx test/e2e/cleanup-cli.ts",
		"test:e2e": "npm run test:e2e:cleanup && npm run build && tsx test/e2e/run-e2e.ts",
		"dev:e2e": "npm run test:e2e:cleanup && npm run build && tsx test/e2e/dev-e2e.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/3p3r/n8n-hooks-marketplace.git"
	},
	"keywords": [
		"n8n",
		"hooks",
		"marketplace",
		"mqtt"
	],
	"author": "Sepehr Laal",
	"license": "MIT",
	"dependencies": {
		"fuse.js": "^7.1.0",
		"mqtt": "^5.14.1",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"uuid": "^13.0.0",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@playwright/test": "^1.57.0",
		"@types/express": "^5.0.6",
		"@types/node": "^25.0.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"aedes": "^0.51.3",
		"n8n": "^2.31.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.0",
		"vitest": "^4.0.16",
		"websocket-stream": "^5.5.2"
	}
}
